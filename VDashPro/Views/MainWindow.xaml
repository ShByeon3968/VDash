<Window x:Class="VDashPro.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VDashPro"
        xmlns:prism="http://prismlibrary.com/"
        xmlns:scottplot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        prism:ViewModelLocator.AutoWireViewModel="True"
        mc:Ignorable="d"
        Title="{Binding Title}" Height="720" Width="1280">
    <Grid Background="#1E1E1E">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="6*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="7*"/>
            <RowDefinition Height="3*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Grid.Column="0" Margin="5">
            <TextBlock Text="Control Panel" Foreground="White" HorizontalAlignment="Center" Margin="10"/>
        </Border>

        <Border Grid.Row="0" Grid.Column="1" Margin="5" Background="Black">
            <TextBlock Text="X-Band Payload Viewer" Foreground="Gray" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <Border Grid.Row="0" Grid.Column="2" Margin="5" Background="#2D2D30">
            <TextBlock Text="AI Analysis" Foreground="White" HorizontalAlignment="Center" Margin="10"/>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="5" Background="#2D2D30">
            <Grid>
                <TextBlock Text="Real-time Telemetry (Altitude &amp; Temp)" Foreground="White" Margin="10,5,0,0" Panel.ZIndex="1"/>
                <scottplot:WpfPlot x:Name="WpfPlot1" Margin="5"/>
            </Grid>
        </Border>
    </Grid>
</Window>
